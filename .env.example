# ts-store configuration
TSSTORE_ADMIN_KEY=your-admin-key-min-20-chars
TSSTORE_API_KEY=tsstore_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Data writer configuration
DATA_WRITER_INTERVAL_MS=1000
DATA_WRITER_NOISE=true
DATA_WRITER_ANOMALY_RATE=0.002

# Database seeder configuration
NUM_SENSORS=10
DAYS_BACK=7
INTERVAL_SECONDS=60

# WebSocket simulator configuration
WS_INTERVAL_MS=1000
WS_NUM_SENSORS=50
WS_ENABLE_NOISE=true
WS_ANOMALY_RATE=0.002
WS_USE_TSSTORE=true

# REST API simulator configuration
API_BUFFER_SIZE=1000
API_GENERATE_MS=5000

# Traffic simulator configuration (AWS Honeypot replay -> globe + Sankey)
TRAFFIC_EVENTS_PER_SEC=50
TRAFFIC_STORE_NAME=traffic-flows
TRAFFIC_AGG_WRITE_SEC=60

# PostgreSQL (for local development)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sensors
